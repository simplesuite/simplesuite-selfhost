# SimpleBudget Self-Hosting Environment Configuration
# Copy this file to .env and run ./deploy/scripts/generate-secrets.sh to populate secrets.

# === Public (browser-safe) ===
# The URL where the Kong API gateway is accessible from the browser.
# This is passed to supabase-js and must be reachable by end users.
SUPABASE_PUBLIC_URL=http://localhost:8000

# Browser-safe JWT with the "anon" role, used by supabase-js for unauthenticated API access.
# Generated automatically by generate-secrets.sh.
ANON_KEY=

# === Private (backend-only) ===
# JWT with the "service_role" role. Must NEVER be exposed to browser clients.
# Generated automatically by generate-secrets.sh.
SERVICE_ROLE_KEY=

# Cryptographic secret used to sign ANON_KEY and SERVICE_ROLE_KEY JWTs.
# Must NEVER be exposed to browser clients.
# Generated automatically by generate-secrets.sh.
JWT_SECRET=

# Password for the Postgres database superuser.
# Must NEVER be exposed to browser clients.
# Generated automatically by generate-secrets.sh.
POSTGRES_PASSWORD=

# === Optional ===
# Username for the Supabase Studio dashboard (if enabled).
DASHBOARD_USERNAME=admin

# Password for the Supabase Studio dashboard.
# Generated automatically by generate-secrets.sh.
DASHBOARD_PASSWORD=

# === Frontend ===
# Port on which the self-hosted frontend container is exposed.
# Only used when running with compose.frontend.yml.
FRONTEND_PORT=8080
